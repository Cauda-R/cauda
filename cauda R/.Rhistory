domain = "wind_energy",
scenario = ifelse(i <= 4, "perfect", ifelse(i <= 8, "realistic", "degraded")),
extraction_mode = "mock_realistic",
f1_score = rnorm(1, mean = 0.82, sd = 0.08),
precision = rnorm(1, mean = 0.80, sd = 0.08),
recall = rnorm(1, mean = 0.85, sd = 0.07),
composite_score = rnorm(1, mean = 0.82, sd = 0.08),
high_confidence_precision_v2 = rnorm(1, mean = 0.85, sd = 0.06),
hallucination_clarity_v2 = rnorm(1, mean = 0.80, sd = 0.07),
high_confidence_hallucination_rate = rnorm(1, mean = 0.10, sd = 0.05),
ready_for_production = TRUE,
num_claims_extracted = sample(15:40, 1)
)
}
