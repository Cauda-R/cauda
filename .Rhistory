if (exists('test_data') && nrow(test_data) > 0) {}
cat("\n>>> Testing DATA ANALYSIS mode...\n")
test_result <- cauda.analyze_unified(data = test_data, analysis_type = "data", verbose = TRUE)
cat("\nData analysis result class:", class(test_result), "\n")
cat("Data analysis complete!\n")
} else {}
cat("test_data not found or empty\n")
}
# Create the unified cauda.analyze function at global level
cauda.analyze_unified <- function(data = NULL, papers = NULL, analysis_type = "auto", )
highlight = "var", confidence_mode = "default",
extraction_mode = "mock_perfect", verbose = TRUE, ...) {}
if (verbose) cat("\n=== CAUDA UNIFIED ANALYSIS ENGINE ===\n")
# Auto-detect analysis type if not specified
. if (analysis_type == "auto") {}
if (!is.null(papers) && (is.character(papers) || is.data.frame(papers))) {}
analysis_type <- "papers"
} else if (!is.null(data) && is.data.frame(data)) {}
analysis_type <- "data"
} else {}
stop("Could not determine analysis type. Provide either data (data.frame) or papers.")
}
}
.
# Route to appropriate analysis function
. ction if (analysis_type == "papers") {}
if (verbose) cat("Routing to PAPER ANALYSIS pipeline...\n")
results <- cauda.analyze_papers(papers = papers, extraction_mode = extraction_mode, )
confidence_mode = confidence_mode, verbose = verbose, ...)
results$analysis_type <- "papers"
results$unified_metadata <- list(timestamp = Sys.time(), system = "CAUDA Unified v1.0", mode = "paper_analysis")
} else if (analysis_type == "data") {}
if (verbose) cat("Routing to DATA ANALYSIS pipeline...\n")
results <- cauda.analyze(df = data, highlight = highlight, verbose = verbose, ...)
results$analysis_type <- "data"
results$unified_metadata <- list(timestamp = Sys.time(), system = "CAUDA Unified v1.0", mode = "data_analysis")
} else {}
.   stop("Unknown analysis_type: ", analysis_type)
}
.  if (verbose) cat("\n=== ANALYSIS COMPLETE ===\n")
. class(results) <- c("cauda_unified_results", class(results))
return(results)
}
